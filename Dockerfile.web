# ─── Stage 1: Install dependencies ───────────────────────────────────────────
FROM node:20-slim AS deps

# Enable pnpm via corepack
RUN corepack enable

WORKDIR /app

# Copy workspace manifests only — maximises layer cache
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY apps/web/package.json                   ./apps/web/
COPY packages/crypto/package.json            ./packages/crypto/
COPY packages/chains/package.json            ./packages/chains/
COPY packages/db/package.json                ./packages/db/
COPY packages/tsconfig/package.json          ./packages/tsconfig/

RUN pnpm install --frozen-lockfile


# ─── Stage 2: Build ───────────────────────────────────────────────────────────
FROM node:20-slim AS builder

RUN corepack enable
WORKDIR /app

# Bring in installed node_modules from deps stage
COPY --from=deps /app/node_modules          ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules

# Copy full source (node_modules and .next excluded via .dockerignore)
COPY . .

# NEXT_PUBLIC_* vars are baked into the JS bundle at build time.
# Pass them as build args: --build-arg NEXT_PUBLIC_FOO=bar
ARG NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""
ARG NEXT_PUBLIC_RPC_ETHEREUM=""
ARG NEXT_PUBLIC_RPC_ARBITRUM=""
ARG NEXT_PUBLIC_RPC_BASE=""
ARG NEXT_PUBLIC_RPC_POLYGON=""

ENV NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=$NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID
ENV NEXT_PUBLIC_RPC_ETHEREUM=$NEXT_PUBLIC_RPC_ETHEREUM
ENV NEXT_PUBLIC_RPC_ARBITRUM=$NEXT_PUBLIC_RPC_ARBITRUM
ENV NEXT_PUBLIC_RPC_BASE=$NEXT_PUBLIC_RPC_BASE
ENV NEXT_PUBLIC_RPC_POLYGON=$NEXT_PUBLIC_RPC_POLYGON

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN pnpm --filter @deepdive/web build


# ─── Stage 3: Production runner ───────────────────────────────────────────────
# Must use debian-based (slim) not alpine — @libsql native binary requires glibc.
FROM node:20-slim AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME=0.0.0.0
# Cloud Run sets PORT=8080 at runtime; this is the local default.
ENV PORT=8080

# With outputFileTracingRoot set to monorepo root, the standalone directory
# mirrors the monorepo structure:
#   apps/web/.next/standalone/
#     apps/web/server.js     ← entry point
#     apps/web/.next/server/ ← SSR bundles
#     node_modules/          ← all traced deps
COPY --from=builder /app/apps/web/.next/standalone       ./
COPY --from=builder /app/apps/web/.next/static           ./apps/web/.next/static
COPY --from=builder /app/apps/web/public                 ./apps/web/public

EXPOSE 8080

# Run as non-root for security
USER node

CMD ["node", "apps/web/server.js"]
