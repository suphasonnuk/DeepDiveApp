# ─── Stage 1: Install + Build ─────────────────────────────────────────────────
# Must use debian-based (slim) not alpine — @libsql native binary requires glibc.
FROM node:20-slim AS builder

RUN corepack enable

WORKDIR /app

# Copy manifests first so pnpm can install external deps and create workspace
# symlinks (node_modules/@deepdive/* → packages/*) while only package.json exists.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json ./
COPY packages/tsconfig/package.json          ./packages/tsconfig/
COPY packages/crypto/package.json            ./packages/crypto/
COPY packages/chains/package.json            ./packages/chains/
COPY packages/db/package.json                ./packages/db/
COPY apps/web/package.json                   ./apps/web/

RUN pnpm install --frozen-lockfile

# Copy workspace source AFTER install. pnpm workspace symlinks are live filesystem
# references — once packages/*/src/ exists here, node_modules/@deepdive/* sees it
# immediately through the symlink chain. No COPY --from needed.
COPY packages/ ./packages/
COPY apps/web/ ./apps/web/

# NEXT_PUBLIC_* vars are baked into the JS bundle at build time.
ARG NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""
ARG NEXT_PUBLIC_RPC_ETHEREUM=""
ARG NEXT_PUBLIC_RPC_ARBITRUM=""
ARG NEXT_PUBLIC_RPC_BASE=""
ARG NEXT_PUBLIC_RPC_POLYGON=""

ENV NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=$NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID
ENV NEXT_PUBLIC_RPC_ETHEREUM=$NEXT_PUBLIC_RPC_ETHEREUM
ENV NEXT_PUBLIC_RPC_ARBITRUM=$NEXT_PUBLIC_RPC_ARBITRUM
ENV NEXT_PUBLIC_RPC_BASE=$NEXT_PUBLIC_RPC_BASE
ENV NEXT_PUBLIC_RPC_POLYGON=$NEXT_PUBLIC_RPC_POLYGON

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN pnpm --filter @deepdive/web build


# ─── Stage 2: Production runner ───────────────────────────────────────────────
FROM node:20-slim AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME=0.0.0.0
# Cloud Run sets PORT=8080 at runtime; this is the local default.
ENV PORT=8080

# With outputFileTracingRoot set to monorepo root, the standalone directory
# mirrors the monorepo structure:
#   apps/web/.next/standalone/
#     apps/web/server.js     ← entry point
#     apps/web/.next/server/ ← SSR bundles
#     node_modules/          ← all traced deps
COPY --from=builder /app/apps/web/.next/standalone       ./
COPY --from=builder /app/apps/web/.next/static           ./apps/web/.next/static
COPY --from=builder /app/apps/web/public                 ./apps/web/public

# Standalone tracer skips serverExternalPackages — install native DB driver explicitly
RUN npm install --no-save @libsql/client libsql drizzle-orm

EXPOSE 8080

# Run as non-root for security
USER node

CMD ["node", "apps/web/server.js"]
