/**
 * DECODE logo — geometric "D" made of stacked bars representing the 3 pillars:
 * Work (top), Future (mid), Body (bottom). The bars form a stylized "D" shape
 * that also resembles a progress/decode signal.
 */
export default function DecodeLogo({ size = 32 }: { size?: number }) {
  return (
    <svg
      width={size}
      height={size}
      viewBox="0 0 64 64"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-label="DECODE logo"
    >
      {/* Background circle */}
      <circle cx="32" cy="32" r="30" fill="oklch(16% 0.020 260)" stroke="oklch(24% 0.025 260)" strokeWidth="1.5" />

      {/* Stylized "D" made of 3 horizontal bars with rounded right ends */}
      {/* Each bar = one pillar: Work (blue-violet), Future (cyan), Body (green) */}

      {/* Vertical stem of D */}
      <rect x="16" y="16" width="4" height="32" rx="2" fill="oklch(74% 0.18 280)" />

      {/* Top bar — Work */}
      <rect x="20" y="16" width="22" height="6" rx="3" fill="oklch(72% 0.16 250)" />

      {/* Middle bar — Future (widest = the belly of the D) */}
      <rect x="20" y="29" width="26" height="6" rx="3" fill="oklch(74% 0.18 280)" />

      {/* Bottom bar — Body */}
      <rect x="20" y="42" width="22" height="6" rx="3" fill="oklch(72% 0.18 150)" />

      {/* Connecting arc on the right (the curve of the D) */}
      <path
        d="M42 19 C52 19 52 45 42 45"
        stroke="oklch(74% 0.18 280)"
        strokeWidth="2.5"
        strokeLinecap="round"
        fill="none"
        opacity="0.5"
      />
    </svg>
  )
}
