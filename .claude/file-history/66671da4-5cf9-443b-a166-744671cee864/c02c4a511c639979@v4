/* ═══════════════════════════════════════════════════
   ANIMATIONS & TRANSITIONS — v6
   Principle: fast-in, slow-out. Spring for pops.
   Reduce motion respected throughout.
   ═══════════════════════════════════════════════════ */

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}

/* ── Core keyframes ──────────────────────────────── */
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes fadeSlideDown {
  from { opacity: 0; transform: translateY(-8px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.94) translateY(8px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}
@keyframes springIn {
  from { opacity: 0; transform: scale(0.90) translateY(14px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}
@keyframes slideLoader {
  0%   { transform: translateX(-100%); }
  100% { transform: translateX(350%); }
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
@keyframes pulse {
  0%,100% { opacity: 1; }
  50%     { opacity: 0.2; }
}
@keyframes bounce {
  0%,100% { transform: translateY(0); }
  50%     { transform: translateY(-4px); }
}
@keyframes float {
  0%,100% { transform: translateY(0); }
  50%     { transform: translateY(-5px); }
}
@keyframes shake {
  0%,100% { transform: translateX(0); }
  20%     { transform: translateX(-4px); }
  60%     { transform: translateX(4px); }
  80%     { transform: translateX(-2px); }
}
@keyframes pop {
  0%   { transform: scale(1); }
  40%  { transform: scale(1.1); }
  100% { transform: scale(1); }
}
@keyframes tickIn {
  from { opacity: 0; transform: scale(0.4); }
  to   { opacity: 1; transform: scale(1); }
}
@keyframes dotPulse {
  0%,100% { box-shadow: 0 0 4px var(--win); }
  50%     { box-shadow: 0 0 10px var(--win), 0 0 18px var(--win); }
}
@keyframes expandDown {
  from { opacity: 0; max-height: 0; }
  to   { opacity: 1; max-height: 600px; }
}
@keyframes barGrow {
  from { width: 0; }
}

/* ── Splash screen — premium loading ─────────────── */
.splash-screen {
  min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: var(--sp-4);
  animation: fadeIn 0.35s var(--ease) both;
  background: radial-gradient(ellipse at 50% 40%, oklch(14% 0.012 75), var(--bg) 70%);
}
.splash-logo {
  font-size: 56px;
  animation: float 2.5s var(--ease-out-quint) infinite;
  filter: drop-shadow(0 6px 16px oklch(0% 0 0 / 0.4));
}
.splash-title {
  font-family: var(--font-display);
  font-weight: var(--weight-black); font-size: var(--text-3xl);
  color: var(--accent); letter-spacing: -0.5px;
  animation: fadeSlideUp 0.4s var(--ease) 0.1s both;
}
.splash-loader {
  width: 120px; height: 2px;
  background: var(--border2);
  border-radius: var(--radius-full); overflow: hidden;
  margin-top: var(--sp-3);
  animation: fadeIn 0.4s var(--ease) 0.2s both;
}
.splash-bar {
  height: 100%; width: 40%;
  background: linear-gradient(90deg, var(--accent), oklch(82% 0.14 85 / 0.6));
  border-radius: var(--radius-full);
  animation: slideLoader 1.1s var(--ease) infinite;
}

/* ── Tab transitions ─────────────────────────────── */
.tab-enter   {
  animation: fadeSlideUp 0.22s var(--ease) both;
}
.tab-exit    {
  opacity: 0;
  transform: translateY(4px);
  transition: opacity 0.14s var(--ease), transform 0.14s var(--ease);
  pointer-events: none;
}

/* ── Page intro ──────────────────────────────────── */
.page-intro { animation: fadeSlideDown 0.2s var(--ease) both; }

/* ── Cards ───────────────────────────────────────── */
.card { animation: fadeSlideUp 0.22s var(--ease) both; }

.task-card { animation: fadeSlideUp 0.22s var(--ease) both; }
.task-card:nth-child(1) { animation-delay: 0.02s; }
.task-card:nth-child(2) { animation-delay: 0.06s; }
.task-card:nth-child(3) { animation-delay: 0.10s; }

/* ── Buttons ─────────────────────────────────────── */
.btn-primary, .btn-success, .btn-secondary {
  transition:
    opacity var(--t-fast) var(--ease),
    transform var(--t-fast) var(--ease),
    box-shadow var(--t-base) var(--ease),
    background var(--t-base) var(--ease),
    border-color var(--t-base) var(--ease);
}
.done-btn {
  transition: all var(--t-base) var(--ease);
}
.done-btn:active     { transform: scale(0.94); }
.done-btn-active     { animation: pop 0.22s var(--ease-out-quint) both; }

/* ── Outcome cards ───────────────────────────────── */
.outcome-card {
  transition: transform var(--t-fast) var(--ease),
              border-color var(--t-base) var(--ease),
              background var(--t-base) var(--ease),
              box-shadow var(--t-base) var(--ease);
}
.outcome-card:hover  { transform: translateY(-2px); }
.outcome-card:active { transform: scale(0.97); }
.outcome-card:nth-child(1) { animation: fadeSlideUp 0.2s var(--ease) 0.00s both; }
.outcome-card:nth-child(2) { animation: fadeSlideUp 0.2s var(--ease) 0.05s both; }
.outcome-card:nth-child(3) { animation: fadeSlideUp 0.2s var(--ease) 0.10s both; }

/* ── Checkbox ────────────────────────────────────── */
.check-box.done::after { animation: tickIn 0.14s var(--ease-out-quint) both; }

/* ── Sliders ─────────────────────────────────────── */
.energy-slider::-webkit-slider-thumb {
  transition: transform 0.14s var(--ease), box-shadow 0.14s var(--ease);
}
.energy-slider:hover::-webkit-slider-thumb,
.energy-slider:active::-webkit-slider-thumb {
  transform: scale(1.25);
  box-shadow: 0 0 0 7px oklch(82% 0.14 85 / 0.12);
}

/* ── Tab button active bar ───────────────────────── */
.tab-btn::after {
  content: '';
  display: block;
  height: 2px; width: 0;
  background: var(--accent);
  border-radius: 1px;
  margin-top: 3px;
  transition: width var(--t-base) var(--ease);
}
.tab-btn-active::after { width: 100%; }

/* ── Macro/progress bars ─────────────────────────── */
.nutr-macro-bar-fill,
.dash-today-bar-fill {
  animation: barGrow 0.5s var(--ease) both;
}

/* ── Daily status bar ────────────────────────────── */
.daily-status {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 18px;
  font-size: 12px; cursor: pointer;
  border-bottom: 1px solid var(--border);
  transition: background var(--t-base) var(--ease);
  animation: fadeSlideDown 0.25s var(--ease) both;
}
.daily-status:hover { background: oklch(95% 0.008 75 / 0.025); }
.daily-status-active { background: oklch(82% 0.14 85 / 0.04) !important; }
.daily-status-done    { color: var(--win); }
.daily-status-morning { color: var(--work); }
.daily-status-night   { color: var(--body); }
.daily-status-urgent  { color: var(--miss); }
.ds-icon  { font-size: 15px; flex-shrink: 0; }
.ds-text  { flex: 1; line-height: 1.3; }
.ds-message { font-size: 12px; color: var(--text); }
.ds-message strong { font-weight: 600; }
.ds-sub { font-size: 10px; color: var(--muted2); margin-top: 1px; }
.ds-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
.ds-dots  { display: flex; gap: 4px; }
.ds-dot   {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--border2);
  transition: background var(--t-base) var(--ease), transform var(--t-base) var(--ease);
}
.ds-dot-done { transform: scale(1.15); }
.ds-arrow { font-size: 12px; opacity: 0.4; flex-shrink: 0; transition: transform var(--t-base) var(--ease), opacity var(--t-base) var(--ease); }
.daily-status:hover .ds-arrow { transform: translateX(4px); opacity: 1; }

/* ── Onboarding — premium feel ──────────────────── */
.onboard-gate {
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  padding: var(--sp-6);
  background: radial-gradient(ellipse at 50% 30%, oklch(14% 0.012 75), var(--bg) 70%);
}
.onboard-card {
  background: var(--surface);
  border: 1px solid var(--border2);
  border-radius: var(--radius-xl);
  padding: var(--sp-12) var(--sp-8) var(--sp-8);
  width: 100%; max-width: 380px;
  text-align: center;
  box-shadow: var(--shadow-lg);
  position: relative;
  overflow: hidden;
}
.onboard-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--work), var(--accent), var(--body));
}
.onboard-enter { animation: springIn 0.4s var(--ease-out-quint) both; }
.onboard-exit  { animation: scaleIn 0.2s var(--ease) reverse both; }
.onboard-emoji {
  font-size: 56px; margin-bottom: var(--sp-5); display: block;
  animation: float 3.5s var(--ease) infinite;
  filter: drop-shadow(0 4px 12px oklch(0% 0 0 / 0.3));
}
.onboard-title {
  font-family: var(--font-display);
  font-weight: var(--weight-black); font-size: var(--text-2xl);
  color: var(--accent); margin-bottom: var(--sp-1);
  letter-spacing: -0.3px;
}
.onboard-sub {
  font-size: var(--text-sm); color: var(--muted2);
  letter-spacing: 0.5px; margin-bottom: var(--sp-5);
}
.onboard-body {
  font-size: var(--text-base); color: var(--text);
  line-height: 1.7; margin-bottom: var(--sp-8);
}
.onboard-btn { width: 100%; margin-bottom: var(--sp-5); }
.onboard-dots { display: flex; justify-content: center; gap: var(--sp-2); margin-bottom: var(--sp-3); }
.onboard-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--border2);
  transition: all var(--t-base) var(--ease-out-quint);
}
.onboard-dot-active {
  background: var(--accent);
  transform: scale(1.4);
  box-shadow: 0 0 8px oklch(82% 0.14 85 / 0.3);
}
.onboard-skip {
  background: none; border: none; font-family: var(--font-mono);
  font-size: var(--text-sm); color: var(--muted); cursor: pointer;
  transition: color var(--t-base) var(--ease);
}
.onboard-skip:hover { color: var(--muted2); }

/* ── Modal ───────────────────────────────────────── */
.modal-overlay { animation: fadeIn 0.18s var(--ease) both; }
.modal         { animation: scaleIn 0.22s var(--ease-out-quint) both; }

/* ── Banners ─────────────────────────────────────── */
.yesterday-banner { animation: fadeSlideDown 0.25s var(--ease) 0.08s both; opacity: 0; animation-fill-mode: forwards; }
.info-banner      { animation: fadeSlideDown 0.22s var(--ease) both; }
.warning-banner   { animation: fadeSlideUp 0.22s var(--ease) both, shake 0.4s var(--ease) 0.25s; }
.streak-banner    { animation: springIn 0.32s var(--ease-out-quint) both; }
.nutr-nudge-banner { animation: fadeSlideDown 0.25s var(--ease) both; }

/* ── Toast — polished notification ───────────────── */
.toast {
  position: fixed; bottom: 28px; left: 50%;
  transform: translateX(-50%) translateY(14px) scale(0.95);
  padding: var(--sp-3) var(--sp-6);
  border-radius: var(--radius-full);
  font-family: var(--font-mono); font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  opacity: 0;
  transition: opacity var(--t-slow) var(--ease-out-quint),
              transform var(--t-slow) var(--ease-out-quint);
  pointer-events: none; white-space: nowrap; z-index: 999;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}
.toast-ok {
  background: oklch(76% 0.12 150 / 0.92);
  color: oklch(10% 0.008 75);
  box-shadow: 0 8px 24px oklch(76% 0.12 150 / 0.3);
}
.toast-err {
  background: oklch(62% 0.20 25 / 0.92);
  color: oklch(95% 0.008 75);
  box-shadow: 0 8px 24px oklch(62% 0.20 25 / 0.3);
}
.toast-show {
  opacity: 1;
  transform: translateX(-50%) translateY(0) scale(1);
}

/* ── Week expand ─────────────────────────────────── */
.week-expand { animation: expandDown 0.22s var(--ease) both; overflow: hidden; }

/* ── Stat cards ──────────────────────────────────── */
.stat-card { animation: fadeSlideUp 0.22s var(--ease) both; }
.stats-grid .stat-card:nth-child(1) { animation-delay: 0.00s; }
.stats-grid .stat-card:nth-child(2) { animation-delay: 0.04s; }
.stats-grid .stat-card:nth-child(3) { animation-delay: 0.08s; }
.stats-grid .stat-card:nth-child(4) { animation-delay: 0.12s; }

/* ── Chart ───────────────────────────────────────── */
.chart-header { animation: fadeIn 0.3s var(--ease) 0.1s both; }

/* ── Empty state ─────────────────────────────────── */
.empty-state {
  animation: fadeIn 0.3s var(--ease) 0.1s both;
  opacity: 0; animation-fill-mode: forwards;
}

/* ── Server dot ──────────────────────────────────── */
.server-ok .server-dot { animation: dotPulse 2.8s var(--ease) infinite; }

/* ── Score badge ─────────────────────────────────── */
.score-badge { transition: background var(--t-base) var(--ease), color var(--t-base) var(--ease); }

/* ── Spinner ─────────────────────────────────────── */
.spinner {
  width: 13px; height: 13px;
  border: 2px solid oklch(10% 0.01 75 / 0.25);
  border-top-color: oklch(10% 0.01 75);
  border-radius: 50%;
  animation: spin 0.55s linear infinite;
  display: none;
}
.spinner.show { display: inline-block; }

/* ── Sync spinner (see index.css for base style) ── */

/* ── Help rhythm dots ────────────────────────────── */
.help-rhythm-dot { transition: box-shadow var(--t-base) var(--ease); }

/* ── Prof goal button ────────────────────────────── */
.prof-goal-btn {
  transition: border-color var(--t-base) var(--ease),
              background var(--t-base) var(--ease),
              color var(--t-base) var(--ease),
              transform var(--t-fast) var(--ease);
}
.prof-goal-btn:active { transform: scale(0.96); }

/* ── TDEE card ───────────────────────────────────── */
.prof-tdee-card { animation: fadeSlideUp 0.25s var(--ease-out-quint) both; }

/* ── Nutr confirm form ───────────────────────────── */
.nutr-image-preview { animation: scaleIn 0.22s var(--ease-out-quint) both; }
.nutr-impact-card   { animation: fadeSlideUp 0.22s var(--ease) both; }

/* ── Achievement popup ───────────────────────────── */
.achievement-popup { animation: springIn 0.35s var(--ease-out-quint) both; }

/* ── Coach loading dots ──────────────────────────── */
.coach-loading-dots div {
  animation: bounce 1.1s var(--ease) infinite;
}
.coach-loading-dots div:nth-child(2) { animation-delay: 0.15s; }
.coach-loading-dots div:nth-child(3) { animation-delay: 0.30s; }

/* ── Dashboard today steps ───────────────────────── */
.dash-today-step {
  transition: background var(--t-base) var(--ease);
  border-radius: var(--radius-sm);
}
.dash-today-step:hover { background: oklch(95% 0.008 75 / 0.04); }

/* ── Nutr macro bar fill ─────────────────────────── */
.nutr-macro-bar-fill {
  transition: width 0.5s var(--ease);
  animation: barGrow 0.5s var(--ease) both;
}

/* ── Confetti celebration ───────────────────────── */
@keyframes confettiFall {
  0%   { transform: translateY(-10vh) rotate(0deg); opacity: 1; }
  80%  { opacity: 1; }
  100% { transform: translateY(105vh) rotate(720deg); opacity: 0; }
}
.confetti-container {
  position: fixed; inset: 0;
  pointer-events: none; z-index: 1000;
  overflow: hidden;
}
.confetti-particle {
  position: absolute; top: -8px;
  width: 8px; height: 12px;
  border-radius: 2px;
  animation: confettiFall 2s var(--ease) forwards;
}