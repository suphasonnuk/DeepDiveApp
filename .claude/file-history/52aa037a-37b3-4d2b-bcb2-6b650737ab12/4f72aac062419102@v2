            })],
          }),
        ],
      }),
    ],
  });
}

// Callout box with left color bar
function calloutBox(titleText, bodyRuns, barColor, bgColor = LT_GRAY) {
  return new Table({
    width: { size: 9360, type: WidthType.DXA },
    columnWidths: [120, 9240],
    rows: [
      new TableRow({
        children: [
          new TableCell({
            borders: noBorders,
            width: { size: 120, type: WidthType.DXA },
            shading: { fill: barColor, type: ShadingType.CLEAR },
            children: [new Paragraph({ children: [] })],
          }),
          new TableCell({
            borders: noBorders,
            width: { size: 9240, type: WidthType.DXA },
            shading: { fill: bgColor, type: ShadingType.CLEAR },
            margins: { top: 100, bottom: 100, left: 150, right: 150 },
            children: [
              new Paragraph({
                spacing: { after: 80 },
                children: [new TextRun({ text: titleText, font: "Calibri", size: 22, bold: true, color: barColor })],
              }),
              new Paragraph({
                children: bodyRuns.map(r => new TextRun({ text: r.text, font: "Calibri", size: 20, bold: r.bold, italic: r.italic, color: r.color || "313131", break: r.break })),
              }),
            ],
          }),
        ],
      }),
    ],
  });
}

