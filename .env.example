# Authentication
JWT_SECRET=generate-a-random-64-char-hex-string

# WalletConnect (get project ID from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# RPC Endpoints (QuickNode recommended — get endpoints from https://quicknode.com)
# QuickNode provides enhanced APIs for transaction history, event filtering, and token metadata
# Format: https://your-endpoint.quiknode.pro/token/
NEXT_PUBLIC_RPC_ETHEREUM=
NEXT_PUBLIC_RPC_ARBITRUM=
NEXT_PUBLIC_RPC_BASE=
NEXT_PUBLIC_RPC_POLYGON=

# Block Explorer APIs (OPTIONAL if using QuickNode — for transaction monitoring fallback)
# QuickNode's enhanced APIs can replace these for transaction history
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=
BASESCAN_API_KEY=
POLYGONSCAN_API_KEY=

# Turso Database (set up at turso.tech)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# DEX APIs
NEXT_PUBLIC_TRADEXYZ_API_KEY=
# Hyperliquid doesn't require an API key for read-only operations

# Smart Money Discovery APIs
MORALIS_API_KEY=
COVALENT_API_KEY=

# Quant Engine
QUANT_ENGINE_URL=http://localhost:8000
QUANT_ENGINE_API_KEY=
