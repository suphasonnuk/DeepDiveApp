# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# On Windows PowerShell: [System.BitConverter]::ToString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32)).Replace('-','').ToLower()
JWT_SECRET=

# ── Turso Database ────────────────────────────────────────────────────────────
# Sign up free at https://app.turso.tech
# Create a database → copy the libsql:// URL and generate a token
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── QuickNode RPC ─────────────────────────────────────────────────────────────
# Sign up free at https://quicknode.com (300M requests/month free)
# Create Endpoint → select Ethereum Mainnet → copy the HTTP Provider URL
# Format: https://your-name.quiknode.pro/your-token/
#
# QUICKNODE_URL    → used server-side to fetch native wallet balance
# NEXT_PUBLIC_RPC_* → used client-side by wagmi for wallet connection
# You can use the same Ethereum QuickNode URL for both.
QUICKNODE_URL=
NEXT_PUBLIC_RPC_ETHEREUM=
NEXT_PUBLIC_RPC_ARBITRUM=
NEXT_PUBLIC_RPC_BASE=
NEXT_PUBLIC_RPC_POLYGON=

# ── Covalent ──────────────────────────────────────────────────────────────────
# Required for ERC-20 token discovery in your wallet (Portfolio tab)
# Sign up free at https://www.covalenthq.com/platform/auth/register/
# Go to API Keys → copy your key
COVALENT_API_KEY=

# ── WalletConnect ─────────────────────────────────────────────────────────────
# Optional — only needed for mobile wallet support (MetaMask mobile, Trust Wallet)
# Sign up at https://cloud.walletconnect.com → create project → copy Project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Quant Engine ──────────────────────────────────────────────────────────────
# URL of the Python FastAPI quant engine
# Local development: http://localhost:8000
# Production (GCP Cloud Run): set to your deployed service URL
QUANT_ENGINE_URL=http://localhost:8000
